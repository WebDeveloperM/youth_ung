# Copy this file to .env and fill in real values before running the server.
# Generate a strong SECRET_KEY with: python -c "import secrets; print(secrets.token_urlsafe(50))"

DJANGO_SECRET_KEY=replace-with-a-strong-random-key
DEBUG=False
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

POSTGRES_DB=youth_database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-strong-db-password
HOST=db
POSTGRES_PORT=5432

CORS_ALLOWED_ORIGINS=https://yourdomain.com
CSRF_TRUSTED_ORIGINS=https://yourdomain.com

# Set to True once HTTPS/SSL is configured
SITE_USES_HTTPS=True

# Django admin URL path — set to something unique and hard to guess
ADMIN_URL_PATH=your-secret-admin-path

# Optional: Ngrok dev tunnel token (dev only)
NGROK_AUTHTOKEN=
